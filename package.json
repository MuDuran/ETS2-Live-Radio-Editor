{
  "name": "ets2-live-radio-editor",
  "version": "0.3.1",
  "description": "Desktop app to manage ETS2 and ATS live radios with local ffmpeg relays.",
  "main": "electron/main.cjs",
  "author": "Murilo Duran",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron .\"",
    "build:renderer": "vite build",
    "verify:release": "node scripts/verify-release-build.cjs",
    "verify:bundled-ffmpeg": "node scripts/verify-bundled-ffmpeg.cjs",
    "verify:packaged-ffmpeg": "node scripts/verify-bundled-ffmpeg.cjs dist-electron/win-unpacked/resources/vendor/ffmpeg/ffmpeg.exe",
    "build": "npm run build:renderer && npm run verify:release && electron-builder",
    "build:release": "npm run build:renderer && npm run verify:release && npm run verify:bundled-ffmpeg && electron-builder --publish never && npm run verify:packaged-ffmpeg",
    "build:release:linux": "npm run build:renderer && npm run verify:release && electron-builder --linux AppImage --publish never",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.muduran.ets2-live-radio-editor",
    "productName": "ETS2 and ATS Live Radio Editor",
    "icon": "assets/icons/ETS2-Radio-Relay-Logo.ico",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "shared/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "vendor",
        "to": "vendor"
      }
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "icon": "assets/icons/ETS2-Radio-Relay-Logo.ico",
      "target": [
        "portable",
        "nsis"
      ],
      "signAndEditExecutable": true
    },
    "linux": {
      "icon": "assets/icons",
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icons/ETS2-Radio-Relay-Logo.ico",
      "uninstallerIcon": "assets/icons/ETS2-Radio-Relay-Logo.ico",
      "installerHeaderIcon": "assets/icons/ETS2-Radio-Relay-Logo.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
